{
    "name": "salehye/settings",
    "description": "A lightweight Laravel settings package with InertiaJS support",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "settings",
        "config",
        "inertiajs",
        "multilingual"
    ],
    "authors": [
        {
            "name": "Saleh",
            "email": "salehye@example.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/salehye/settings/issues",
        "source": "https://github.com/salehye/settings"
    },
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "inertiajs/inertia-laravel": "^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "orchestra/testbench": "^10.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Salehye\\Settings\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Salehye\\Settings\\Tests\\": "tests/",
            "Salehye\\Settings\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Salehye\\Settings\\SettingsServiceProvider"
            ],
            "aliases": {
                "Settings": "Salehye\\Settings\\Facades\\Settings"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
